<div class="min-h-screen flex flex-col" style="background-color: hsl(var(--background));">
  <PetalBoilerplateWeb.ModelComponents.header search_value={@search_value} />
  <PetalBoilerplateWeb.ModelComponents.filter_bar
    filters={@filters}
    providers={@providers}
    active_quick_filters={@active_quick_filters}
  />

  <PetalBoilerplateWeb.ModelComponents.model_detail_modal
    model={@selected_model}
    history_events={@history_events}
    history_meta={@history_meta}
    history_available={@history_available}
    history_api_url={@history_api_url}
  />
  <PetalBoilerplateWeb.ModelComponents.comparison_modal
    is_open={@comparison_open}
    models={selected_models(assigns)}
  />

  <div class="flex-1 w-full max-w-full py-3 px-3 sm:px-4 md:py-4">
    <div class="mb-3 flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
      <div class="text-xs sm:text-sm" style="color: hsl(var(--muted-foreground));">
        <span class="font-medium" style="color: hsl(var(--foreground));">{@total}</span>
        <span class="hidden xs:inline">of {@catalog_total}</span> models
      </div>

      <div class="flex flex-wrap items-center gap-2 xl:justify-end">
        <form phx-change="set_changed_within">
          <label class="sr-only" for="changed-within-select">Changed within</label>
          <select
            id="changed-within-select"
            name="changed_within"
            class="h-9 rounded-md border px-3 text-sm"
            style="border-color: hsl(var(--border)); background-color: hsl(var(--background)); color: hsl(var(--foreground));"
          >
            <option value="" selected={is_nil(@filters.changed_within_days)}>All models</option>
            <option value="7" selected={@filters.changed_within_days == 7}>
              Changed in last 7d
            </option>
            <option value="30" selected={@filters.changed_within_days == 30}>
              Changed in last 30d
            </option>
          </select>
        </form>

        <form phx-change="set_sort">
          <label class="sr-only" for="sort-select">Sort models</label>
          <select
            id="sort-select"
            name="sort"
            class="h-9 rounded-md border px-3 text-sm"
            style="border-color: hsl(var(--border)); background-color: hsl(var(--background)); color: hsl(var(--foreground));"
          >
            <option value="default" selected={sort_control_value(@sort) == "default"}>
              Default order
            </option>
            <option
              value="recently_changed"
              selected={sort_control_value(@sort) == "recently_changed"}
            >
              Recently changed
            </option>
            <option value="custom" disabled selected={sort_control_value(@sort) == "custom"}>
              Custom table sort
            </option>
          </select>
        </form>

        <%= if @total_pages > 1 do %>
          <div class="flex items-center gap-2">
            <button
              type="button"
              phx-click="page"
              phx-value-page={@page - 1}
              disabled={@page <= 1}
              class="px-3 py-1 text-sm border rounded-md disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
              style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
            >
              ← Prev
            </button>
            <span class="text-xs" style="color: hsl(var(--muted-foreground));">
              {@page} / {@total_pages}
            </span>
            <button
              type="button"
              phx-click="page"
              phx-value-page={@page + 1}
              disabled={@page >= @total_pages}
              class="px-3 py-1 text-sm border rounded-md disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
              style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
            >
              Next →
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <div
      class="rounded-lg border overflow-hidden"
      style="border-color: hsl(var(--border)); background-color: hsl(var(--card));"
    >
      <PetalBoilerplateWeb.ModelComponents.model_table
        models={@streams.models}
        sort={@sort}
        total={@total}
        selected_ids={@selected_ids}
        can_add_more={MapSet.size(@selected_ids) < 4}
      />
    </div>

    <%= if @total_pages > 1 do %>
      <div class="flex items-center justify-center gap-2 pt-4">
        <button
          type="button"
          phx-click="page"
          phx-value-page={@page - 1}
          disabled={@page <= 1}
          class="px-3 py-1.5 text-sm border rounded-md disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
          style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
        >
          ← Prev
        </button>
        <span class="text-sm" style="color: hsl(var(--muted-foreground));">
          Page {@page} of {@total_pages}
        </span>
        <button
          type="button"
          phx-click="page"
          phx-value-page={@page + 1}
          disabled={@page >= @total_pages}
          class="px-3 py-1.5 text-sm border rounded-md disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
          style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
        >
          Next →
        </button>
      </div>
    <% end %>
  </div>

  <%= if MapSet.size(@selected_ids) > 0 do %>
    <div
      class="sticky bottom-0 z-40 border-t"
      style="border-color: hsl(var(--border)); background-color: hsl(var(--background)/0.95); backdrop-filter: blur(8px);"
    >
      <div class="w-full max-w-full py-3 px-4">
        <div class="flex items-center justify-between gap-3">
          <div class="text-sm" style="color: hsl(var(--muted-foreground));">
            <span class="font-medium" style="color: hsl(var(--foreground));">
              {MapSet.size(@selected_ids)}
            </span>
            models selected
          </div>
          <div class="flex items-center gap-2">
            <button
              type="button"
              phx-click="clear_comparison"
              class="px-3 py-1.5 text-sm border rounded-md transition-colors"
              style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
            >
              Clear
            </button>
            <button
              type="button"
              phx-click="open_comparison"
              class="px-3 py-1.5 text-sm rounded-md flex items-center gap-1.5 transition-colors"
              style="background-color: hsl(var(--primary)); color: hsl(var(--primary-foreground));"
            >
              <.icon name="hero-arrows-right-left" class="h-4 w-4" /> Compare
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
