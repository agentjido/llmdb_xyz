<div class="min-h-screen flex flex-col" style="background-color: hsl(var(--background));">
  <PetalBoilerplateWeb.ModelComponents.header search_value="" />

  <div class="flex-1 w-full max-w-6xl mx-auto py-8 px-4 sm:px-6">
    <section class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3" style="color: hsl(var(--foreground));">
        Subscription Value Calculator
      </h1>
      <p class="text-base sm:text-lg mb-4" style="color: hsl(var(--muted-foreground));">
        Compare coding subscription value with transparent assumptions, confidence bands, and source links.
      </p>
      <div class="flex flex-wrap gap-2 text-xs sm:text-sm">
        <span
          class="px-2.5 py-1 rounded-full border"
          style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
        >
          No signup
        </span>
        <span
          class="px-2.5 py-1 rounded-full border"
          style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
        >
          No email capture
        </span>
        <span
          class="px-2.5 py-1 rounded-full border"
          style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
        >
          Transparent assumptions
        </span>
      </div>
    </section>

    <section
      class="rounded-lg border p-4 sm:p-6 mb-8"
      style="border-color: hsl(var(--border)); background-color: hsl(var(--card));"
    >
      <form id="subscription-value-form" phx-submit="calculate" class="space-y-6">
        <div>
          <h2 class="text-lg font-semibold mb-3" style="color: hsl(var(--foreground));">
            1) Select up to 4 plans
          </h2>
          <p class="text-sm mb-3" style="color: hsl(var(--muted-foreground));">
            Plans with opaque public limits are still shown, but they are excluded from ranked outputs by default.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <%= for plan <- @plans do %>
              <label
                class="rounded-md border p-3 cursor-pointer transition-colors hover:opacity-90"
                style="border-color: hsl(var(--border));"
              >
                <div class="flex items-start gap-3">
                  <input
                    type="checkbox"
                    name="calculator[selected_plan_ids][]"
                    value={plan.id}
                    checked={selected_plan?(@selected_plan_ids, plan.id)}
                    class="mt-1 h-4 w-4"
                  />
                  <div class="min-w-0">
                    <div class="text-sm font-medium" style="color: hsl(var(--foreground));">
                      {plan.name}
                    </div>
                    <div class="text-xs" style="color: hsl(var(--muted-foreground));">
                      {plan.provider} • {plan_price_label(plan.monthly_price_usd)}
                    </div>
                    <div class="text-xs mt-1" style="color: hsl(var(--muted-foreground));">
                      {limit_type_label(plan.limit_type)} • {reset_window_label(plan.reset_window)}
                    </div>
                  </div>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="workload_profile" class="block text-sm font-medium mb-1">
              Workload profile
            </label>
            <select
              id="workload_profile"
              name="calculator[workload_profile]"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style="border-color: hsl(var(--border)); background-color: hsl(var(--background)); color: hsl(var(--foreground));"
            >
              <option value="light" selected={@workload_profile == "light"}>Light</option>
              <option value="daily" selected={@workload_profile == "daily"}>Daily</option>
              <option value="heavy" selected={@workload_profile == "heavy"}>Heavy</option>
            </select>
          </div>

          <div>
            <label for="model_mix_preset" class="block text-sm font-medium mb-1">
              Model mix preset
            </label>
            <select
              id="model_mix_preset"
              name="calculator[model_mix_preset]"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style="border-color: hsl(var(--border)); background-color: hsl(var(--background)); color: hsl(var(--foreground));"
            >
              <option value="budget" selected={@model_mix_preset == "budget"}>Budget</option>
              <option value="balanced" selected={@model_mix_preset == "balanced"}>
                Balanced
              </option>
              <option value="premium" selected={@model_mix_preset == "premium"}>Premium</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="io_input_pct" class="block text-sm font-medium mb-1">
              Input token ratio (%): {@io_input_pct}
            </label>
            <input
              id="io_input_pct"
              type="range"
              min="10"
              max="95"
              step="1"
              name="calculator[io_input_pct]"
              value={@io_input_pct}
              class="w-full"
            />
            <p class="text-xs mt-1" style="color: hsl(var(--muted-foreground));">
              Output ratio auto-calculates to {100 - @io_input_pct}%.
            </p>
          </div>

          <div>
            <label for="band_mode" class="block text-sm font-medium mb-1">
              Assumption band
            </label>
            <select
              id="band_mode"
              name="calculator[band_mode]"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style="border-color: hsl(var(--border)); background-color: hsl(var(--background)); color: hsl(var(--foreground));"
            >
              <option value="conservative" selected={@band_mode == "conservative"}>
                Conservative
              </option>
              <option value="expected" selected={@band_mode == "expected"}>Expected</option>
              <option value="aggressive" selected={@band_mode == "aggressive"}>Aggressive</option>
            </select>
          </div>
        </div>

        <div>
          <button
            type="button"
            phx-click="toggle_advanced"
            class="text-sm underline underline-offset-2 hover:opacity-80"
            style="color: hsl(var(--primary));"
          >
            <%= if @show_advanced do %>
              Hide advanced assumptions
            <% else %>
              Show advanced assumptions
            <% end %>
          </button>

          <%= if @show_advanced do %>
            <div
              class="mt-3 rounded-md border p-3 grid grid-cols-1 md:grid-cols-2 gap-3"
              style="border-color: hsl(var(--border)); background-color: hsl(var(--background));"
            >
              <div>
                <label for="override_min_units" class="block text-sm font-medium mb-1">
                  Manual min units/window (optional)
                </label>
                <input
                  id="override_min_units"
                  type="number"
                  step="0.01"
                  min="0"
                  name="calculator[override_min_units]"
                  value={@override_min_units}
                  class="w-full rounded-md border px-3 py-2 text-sm"
                  style="border-color: hsl(var(--border)); background-color: hsl(var(--card)); color: hsl(var(--foreground));"
                />
              </div>
              <div>
                <label for="override_max_units" class="block text-sm font-medium mb-1">
                  Manual max units/window (optional)
                </label>
                <input
                  id="override_max_units"
                  type="number"
                  step="0.01"
                  min="0"
                  name="calculator[override_max_units]"
                  value={@override_max_units}
                  class="w-full rounded-md border px-3 py-2 text-sm"
                  style="border-color: hsl(var(--border)); background-color: hsl(var(--card)); color: hsl(var(--foreground));"
                />
              </div>
              <p class="text-xs md:col-span-2" style="color: hsl(var(--muted-foreground));">
                Manual override is applied to plans that do not publish a reliable usage range.
              </p>
            </div>
          <% end %>
        </div>

        <button
          type="submit"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-md font-medium hover:opacity-90"
          style="background-color: hsl(var(--primary)); color: hsl(var(--primary-foreground));"
        >
          <.icon name="hero-calculator" class="h-4 w-4" /> Run calculator
        </button>
      </form>
    </section>

    <%= if @calculated? do %>
      <section
        class="rounded-lg border p-4 sm:p-6 mb-8"
        style="border-color: hsl(var(--border)); background-color: hsl(var(--card));"
      >
        <h2 class="text-xl font-semibold mb-2" style="color: hsl(var(--foreground));">
          Results
        </h2>
        <p class="text-sm mb-4" style="color: hsl(var(--muted-foreground));">
          Profile: {workload_label(@workload_profile)} • Mix: {model_mix_label(@model_mix_preset)} • I/O: {@io_input_pct}/{100 -
            @io_input_pct} • Band: {band_mode_label(@band_mode)}
        </p>

        <%= if @ranked_results == [] do %>
          <div
            class="rounded-md border p-3 mb-4"
            style="border-color: hsl(var(--border)); background-color: hsl(var(--background));"
          >
            <p class="text-sm" style="color: hsl(var(--muted-foreground));">
              No high-confidence ranked output is available for the selected plans. Adjust assumptions or select plans with clearer published limits.
            </p>
          </div>
        <% else %>
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b" style="border-color: hsl(var(--border));">
                  <th class="text-left py-2 pr-3">Rank</th>
                  <th class="text-left py-2 pr-3">Plan</th>
                  <th class="text-left py-2 pr-3">Confidence</th>
                  <th class="text-left py-2 pr-3">Implied API value band</th>
                  <th class="text-left py-2 pr-3">Value multiple band</th>
                  <th class="text-left py-2 pr-3">Equivalent tokens band</th>
                </tr>
              </thead>
              <tbody>
                <%= for result <- @ranked_results do %>
                  <tr class="border-b align-top" style="border-color: hsl(var(--border));">
                    <td class="py-3 pr-3 font-semibold">#{result.rank}</td>
                    <td class="py-3 pr-3">
                      <div class="font-medium">{result.plan_name}</div>
                      <div class="text-xs" style="color: hsl(var(--muted-foreground));">
                        {result.provider} •
                        <%= if is_number(result.monthly_price_usd) do %>
                          ${format_currency(result.monthly_price_usd)}/mo
                        <% else %>
                          price not published
                        <% end %>
                      </div>
                    </td>
                    <td class="py-3 pr-3">
                      <span class={"inline-flex px-2 py-1 rounded-full text-xs font-medium #{confidence_class(result.confidence)}"}>
                        {String.upcase(to_string(result.confidence))}
                      </span>
                    </td>
                    <td class="py-3 pr-3 font-mono">
                      ${format_currency(result.implied_api_value_usd_low)} -
                      ${format_currency(result.implied_api_value_usd_mid)} -
                      ${format_currency(result.implied_api_value_usd_high)}
                    </td>
                    <td class="py-3 pr-3 font-mono">
                      {format_multiple(result.value_multiple_low)} / {format_multiple(
                        result.value_multiple_mid
                      )} / {format_multiple(result.value_multiple_high)}
                    </td>
                    <td class="py-3 pr-3 font-mono">
                      {format_tokens(result.equivalent_tokens_low)} / {format_tokens(
                        result.equivalent_tokens_mid
                      )} / {format_tokens(result.equivalent_tokens_high)}
                    </td>
                  </tr>
                  <tr class="border-b" style="border-color: hsl(var(--border));">
                    <td></td>
                    <td colspan="5" class="pb-3 pt-1 pr-3">
                      <details>
                        <summary class="cursor-pointer text-xs font-medium mb-1">
                          Why this result
                        </summary>
                        <ul
                          class="list-disc list-inside text-xs"
                          style="color: hsl(var(--muted-foreground));"
                        >
                          <%= for driver <- result.drivers do %>
                            <li>{driver}</li>
                          <% end %>
                        </ul>
                      </details>
                      <details class="mt-2">
                        <summary class="cursor-pointer text-xs font-medium mb-1">Sources</summary>
                        <ul
                          class="list-disc list-inside text-xs"
                          style="color: hsl(var(--muted-foreground));"
                        >
                          <%= for source <- result.source_urls do %>
                            <li>
                              <a
                                href={source}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="underline underline-offset-2"
                                style="color: hsl(var(--primary));"
                              >
                                {source}
                              </a>
                            </li>
                          <% end %>
                        </ul>
                      </details>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>

        <%= if @insufficient_results != [] do %>
          <div
            class="rounded-md border p-4"
            style="border-color: hsl(var(--border)); background-color: hsl(var(--background));"
          >
            <h3 class="text-sm font-semibold mb-2" style="color: hsl(var(--foreground));">
              Insufficient precision (not ranked)
            </h3>
            <p class="text-xs mb-3" style="color: hsl(var(--muted-foreground));">
              These plans have limited public limit transparency. They are shown for completeness without rank ordering.
            </p>
            <div class="space-y-3">
              <%= for result <- @insufficient_results do %>
                <div class="rounded-md border p-3" style="border-color: hsl(var(--border));">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class="font-medium text-sm">{result.plan_name}</span>
                    <span class={"inline-flex px-2 py-1 rounded-full text-xs font-medium #{confidence_class(result.confidence)}"}>
                      {String.upcase(to_string(result.confidence))}
                    </span>
                  </div>
                  <ul
                    class="list-disc list-inside text-xs"
                    style="color: hsl(var(--muted-foreground));"
                  >
                    <%= for driver <- result.drivers do %>
                      <li>{driver}</li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>
    <% end %>

    <%= if @show_support_cta and (@ranked_results != [] or @insufficient_results != []) do %>
      <section
        id="support-cta"
        phx-hook="SupportCta"
        class="rounded-lg border p-4 sm:p-6 mb-8"
        style="border-color: hsl(var(--border)); background-color: hsl(var(--card));"
      >
        <h2 class="text-xl font-semibold mb-2" style="color: hsl(var(--foreground));">
          Support open dev tooling
        </h2>
        <p class="text-sm mb-4" style="color: hsl(var(--muted-foreground));">
          If this comparison helped, star Jido and ReqLLM so we can keep research and calculators free.
        </p>
        <div class="flex flex-wrap gap-2">
          <a
            data-support-action="star-jido"
            href="https://github.com/agentjido/jido"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-3 py-2 rounded-md font-medium hover:opacity-90"
            style="background-color: hsl(var(--primary)); color: hsl(var(--primary-foreground));"
          >
            <.icon name="hero-star" class="h-4 w-4" /> Star Jido
          </a>
          <a
            data-support-action="star-req-llm"
            href="https://github.com/agentjido/req_llm"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-3 py-2 rounded-md font-medium hover:opacity-90"
            style="background-color: hsl(var(--primary)); color: hsl(var(--primary-foreground));"
          >
            <.icon name="hero-star" class="h-4 w-4" /> Star ReqLLM
          </a>
          <button
            type="button"
            data-support-action="skip"
            phx-click="dismiss_support_cta"
            class="inline-flex items-center px-3 py-2 rounded-md border hover:opacity-90"
            style="border-color: hsl(var(--border)); color: hsl(var(--foreground));"
          >
            Skip
          </button>
        </div>
        <p class="text-xs mt-3" style="color: hsl(var(--muted-foreground));">
          No signup. No email. No account linking.
        </p>
      </section>
    <% end %>

    <section
      class="rounded-lg border p-4 sm:p-6"
      style="border-color: hsl(var(--border)); background-color: hsl(var(--card));"
    >
      <details>
        <summary class="cursor-pointer text-base font-semibold">Methodology</summary>
        <div class="mt-3 text-sm space-y-2" style="color: hsl(var(--muted-foreground));">
          <p>
            This calculator converts subscription assumptions into API-equivalent value bands.
            It uses LLMDB model pricing metadata, published plan limits where available, and explicit workload assumptions.
          </p>
          <p>
            For plans with opaque limits, we report low-confidence outputs and exclude them from ranking by default.
          </p>
          <p>
            These values are directional estimates, not vendor guarantees.
          </p>
        </div>
      </details>
    </section>
  </div>
</div>
